NODE_ENV=development
PORT=8080
CORS_ORIGIN=https://study-snap-addon-fontend-phi.vercel.app
JWT_SECRET=replace_me
JWT_EXPIRES_IN_SECONDS=600
SESSION_MAX_REQUESTS_PER_MINUTE=30
WS_MAX_PAYLOAD_BYTES=524288
WS_MAX_MESSAGES_PER_10S=60
PARAKEET_MODEL_PATH=../parakeet-tdt-0.6b-v2.nemo
PARAKEET_LANGUAGE=en-US
PARAKEET_SAMPLE_RATE=16000
PARAKEET_MOCK_MODE=true
PARAKEET_PYTHON_COMMAND=python
PARAKEET_INFER_SCRIPT_PATH=./scripts/parakeet_transcribe.py
PARAKEET_INFER_INTERVAL_MS=5000
PARAKEET_INFERENCE_TIMEOUT_MS=120000
PARAKEET_MAX_BUFFERED_SECONDS=120
BACKEND_BASE_URL=http://localhost:8080
TEST_ORIGIN=http://localhost:3000
SMOKE_CHUNK_DURATION_MS=250
SMOKE_CHUNK_COUNT=20
